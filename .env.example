# ==============================================
# BIM9 Pipes License Generator - Environment Variables
# ==============================================

# Server Configuration
PORT=3000

# Email Configuration (Gmail)
# Get App Password from: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password

# PayPal Configuration
# Use 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox

# PayPal API Credentials (Optional - for advanced features)
# Get from: https://developer.paypal.com/dashboard/
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret

# ==============================================
# License Packages (Already configured in code)
# ==============================================
# Monthly:  $9.90  -> 30 days
# 3-Month:  $27.00 -> 90 days
# 6-Month:  $51.00 -> 180 days
# Annual:   $90.00 -> 360 days
# ==============================================

# IMPORTANT NOTES:
# 1. Never commit the actual .env file to Git
# 2. Copy this file to .env and fill in your real credentials
# 3. For Render.com deployment, add these as Environment Variables in the dashboard
# 4. Email password must be a Gmail App Password (not your regular password)
# 5. For production, set PAYPAL_MODE=live
