# ============================================================
# BIM9 PIPES LICENSE GENERATOR - ENVIRONMENT VARIABLES
# ============================================================

# ============================================================
# EMAIL CONFIGURATION
# ============================================================

# Choose email provider: 'gmail' or 'resend'
# Resend is recommended for production (more reliable, better deliverability)
EMAIL_PROVIDER=resend

# ------------------------------------------------------------
# OPTION 1: RESEND.COM (RECOMMENDED FOR PRODUCTION)
# ------------------------------------------------------------
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_API_KEY_HERE

# FROM email address (must be from a verified domain in Resend)
# Example: noreply@yourdomain.com
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ------------------------------------------------------------
# OPTION 2: GMAIL (FOR TESTING/DEVELOPMENT)
# ------------------------------------------------------------
# Your Gmail address
EMAIL_USER=your.email@gmail.com

# Gmail App Password (NOT your regular password!)
# Generate at: https://myaccount.google.com/apppasswords
# Must enable 2-Step Verification first
EMAIL_PASS=your-16-char-app-password

# ============================================================
# PAYPAL CONFIGURATION
# ============================================================

# PayPal mode: 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox

# PayPal Client ID (from PayPal Developer Dashboard)
# Sandbox: https://developer.paypal.com/dashboard/applications/sandbox
# Live: https://developer.paypal.com/dashboard/applications/live
PAYPAL_CLIENT_ID=your-paypal-client-id

# PayPal Secret (optional, for webhook verification)
PAYPAL_SECRET=your-paypal-secret

# ============================================================
# SERVER CONFIGURATION
# ============================================================

# Server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================

# FOR RESEND (RECOMMENDED):
# 1. Sign up at https://resend.com
# 2. Verify your domain (add DNS records)
# 3. Create an API key
# 4. Set EMAIL_PROVIDER=resend
# 5. Set RESEND_API_KEY and RESEND_FROM_EMAIL
# 6. Test with: curl -X POST http://localhost:3000/test-email -H "Content-Type: application/json" -d '{"email":"test@example.com"}'

# FOR GMAIL:
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
# 4. Copy the 16-character password (no spaces!)
# 5. Set EMAIL_PROVIDER=gmail
# 6. Set EMAIL_USER and EMAIL_PASS
# 7. Test with: curl -X POST http://localhost:3000/test-email -H "Content-Type: application/json" -d '{"email":"test@example.com"}'

# FOR PAYPAL:
# 1. Create PayPal Developer account: https://developer.paypal.com
# 2. Create an app in the Developer Dashboard
# 3. Copy Client ID and Secret
# 4. For production, switch to live credentials
# 5. Set up webhooks: https://developer.paypal.com/dashboard/webhooks
#    - Webhook URL: https://yourdomain.com/webhook/paypal
#    - Events to subscribe: All payment events

# ============================================================
# TESTING
# ============================================================

# Test email sending:
# curl -X POST http://localhost:3000/test-email \
#   -H "Content-Type: application/json" \
#   -d '{"email":"your-test-email@example.com"}'

# Test manual license generation:
# curl -X POST http://localhost:3000/generate-key \
#   -H "Content-Type: application/json" \
#   -d '{"email":"customer@example.com","validDays":30,"amount":9.9}'

# Check server status:
# curl http://localhost:3000

# ============================================================
# PRODUCTION NOTES
# ============================================================

# 1. ALWAYS use Resend for production (better deliverability)
# 2. Set PAYPAL_MODE=live for production
# 3. Use environment variables in your hosting platform (Heroku, Railway, etc.)
# 4. Never commit .env file to git
# 5. Keep API keys secure
# 6. Monitor logs for any issues
# 7. Set up webhook URL in PayPal Dashboard
# 8. Test thoroughly in sandbox before going live
